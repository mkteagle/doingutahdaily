{
  "name": "doingutahdaily-monorepo",
  "version": "1.0.0",
  "description": "doingutahdaily monorepo with public site and admin dashboard",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:all": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:push": "pnpm --filter db push",
    "db:studio": "pnpm --filter db studio",
    "db:seed": "pnpm --filter db seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"],
    "overrides": {
      "picomatch": "^4.0.4",
      "minimatch": "^10.2.3",
      "brace-expansion": "^5.0.5",
      "yaml": "^2.8.3"
    }
  },
  "devDependencies": {
    "next": "^16.2.1"
  }
}
