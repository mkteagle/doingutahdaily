# Database
DATABASE_URL="postgresql://user:password@region.neon.tech/dbname?sslmode=require"

# Public API URL
NEXT_PUBLIC_API_URL="https://doingutahdaily.com"

# Instagram Graph API
INSTAGRAM_GRAPH_TOKEN="your_instagram_graph_token"
INSTAGRAM_BUSINESS_ACCOUNT_ID="your_business_account_id"

# Google Calendar
GOOGLE_CLIENT_EMAIL="your_google_client_email"
GOOGLE_PRIVATE_KEY="your_google_private_key"
GOOGLE_CALENDAR_ID="your_calendar_id"

# Unsplash
UNSPLASH_ACCESS_KEY="your_unsplash_key"

# Local content worker
CONTENT_WORKER_URL="http://127.0.0.1:4010"
CONTENT_WORKER_SECRET="your_content_worker_shared_secret"

# TaskJunky bridge
TASKJUNKY_API_BASE_URL="https://taskjunky.app"
TASKJUNKY_API_TOKEN="your_taskjunky_api_token"
TASKJUNKY_WORKER_ID="mac-mini-content-worker"
TASKJUNKY_POLL_INTERVAL_MS="5000"
TASKJUNKY_CLAIM_PATH="/api/worker-jobs/claim"
TASKJUNKY_COMPLETE_PATH="/api/worker-jobs/:jobId/complete"
TASKJUNKY_FAIL_PATH="/api/worker-jobs/:jobId/fail"

# AI drafting used by the local content worker
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-5-mini"

# Scheduled publishing
CRON_SECRET="your_cron_secret"

# Auth.js / Next.js auth
AUTH_SECRET="generate_a_long_random_secret"
AUTH_TRUST_HOST="true"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# Apple OAuth
# APPLE_SERVICE_ID / APPLE_CLIENT_ID should usually be your Apple Services ID (web)
# APPLE_CLIENT_SECRET is the generated Apple client secret JWT
APPLE_SERVICE_ID="your_apple_services_id"
APPLE_CLIENT_ID="your_apple_services_id"
APPLE_CLIENT_SECRET="your_generated_apple_client_secret"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
