# Database
DATABASE_URL="postgresql://user:password@region.neon.tech/dbname?sslmode=require"

# Public API URL
NEXT_PUBLIC_API_URL="https://doingutahdaily.com"

# Instagram Graph API
INSTAGRAM_GRAPH_TOKEN="your_instagram_graph_token"
INSTAGRAM_BUSINESS_ACCOUNT_ID="your_business_account_id"

# Google Calendar
GOOGLE_CLIENT_EMAIL="your_google_client_email"
GOOGLE_PRIVATE_KEY="your_google_private_key"
GOOGLE_CALENDAR_ID="your_calendar_id"

# Unsplash
UNSPLASH_ACCESS_KEY="your_unsplash_key"

# AI drafting
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-5-mini"

# Scheduled publishing
CRON_SECRET="your_cron_secret"

# Auth.js / Next.js auth
AUTH_SECRET="generate_a_long_random_secret"
AUTH_TRUST_HOST="true"

# Google OAuth
AUTH_GOOGLE_ID="your_google_oauth_client_id"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# Apple OAuth
# AUTH_APPLE_ID should usually be your Apple Services ID (web) or client ID
# AUTH_APPLE_SECRET is the generated Apple client secret JWT
AUTH_APPLE_ID="your_apple_services_id"
AUTH_APPLE_SECRET="your_generated_apple_client_secret"

# Optional raw Apple signing inputs if you want to generate AUTH_APPLE_SECRET yourself
APPLE_SERVICE_ID="your_apple_services_id"
APPLE_TEAM_ID="your_apple_team_id"
APPLE_KEY_ID="your_apple_key_id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
